# AI Marketing Hub — Frontend Environment Variables
# Copy this file to .env.local and adjust for your environment.
# .env.local is git-ignored and never committed with secrets.

# ─── Backend API base URL (no trailing slash) ──────────────────────────────
# Must include the /api prefix since all backend routes use prefix="/api".
# Default for local dev: http://localhost:8000/api
# For production: set to the deployed backend URL, e.g. https://api.yourdomain.com/api
# For Docker Compose: use the service name, e.g. http://backend:8000/api
VITE_API_BASE_URL=http://localhost:8000/api

# ─── Notes ──────────────────────────────────────────────────────────────────
# • All VITE_* variables are embedded at BUILD TIME (not runtime).
#   Changing them requires rebuilding the frontend.
# • The backend should have CORS configured to allow the frontend origin.
# • If no value is set, the frontend falls back to http://localhost:8000/api.
