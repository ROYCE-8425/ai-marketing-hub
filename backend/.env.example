# AI Marketing Hub - Backend environment template
# Copy to .env and fill real values when needed.

# --- Core AI ---
GROQ_API_KEY=

# --- Google Custom Search (SERP) ---
# Free: 100 queries/day | Paid: $5/1000 queries
# Get API key: https://console.cloud.google.com/apis/credentials
# Create CX: https://programmablesearchengine.google.com/controlpanel/create
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# --- Google Search Console ---
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=
GSC_SITE_URL=

# --- Google Analytics 4 ---
GA4_PROPERTY_ID=
GA4_CREDENTIALS_PATH=

# --- DataForSEO ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- WordPress Publisher ---
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
